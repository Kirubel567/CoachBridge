DATABASE_URL="postgresql://coachbridge_user:coachbridge_password@localhost:5432/coachbridge_db"

# -----------------------------
# JWT / Authentication
# -----------------------------
JWT_SECRET="your_jwt_secret_here"  # Secret key used to sign JWT access and refresh tokens

# -----------------------------
# Server configuration
# -----------------------------
PORT=3000  # Port where the backend server will run
FRONTEND_URL="http://localhost:3000"  # Frontend app URL for redirects (OAuth success, etc.)

# -----------------------------
# Cloudinary (File / Image storage)
# -----------------------------
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
CLOUDINARY_ENVIRONMENT_VARIABLE=CLOUDINARY_URL=cloudinary://your_cloudinary_api_key:your_cloudinary_api_secret@your_cloudinary_cloud_name
# Cloudinary environment variable format used by their SDKs

# -----------------------------
# SMTP (Email service)
# -----------------------------
SMTP_USER=your_email@example.com  # Email used for sending notifications or password resets
SMTP_PASS='your_email_app_password'  # App password or SMTP password

# -----------------------------
# Google OAuth 2.0
# -----------------------------
GOOGLE_CLIENT_ID="357774902525-ah7e1vtmfq6v870qgmpq5.apps.googleusercontent.com"  # Google OAuth client ID
GOOGLE_CLIENT_SECRET="GOCSPX-x7IxpHBo4-SdnzfDKse"  # Google OAuth client secret
GOOGLE_REDIRECT_URI="http://localhost:3000/api/v1/auth/google/callback"  # Redirect URI registered in Google Cloud Console

# -----------------------------
# Redis (Caching / Session store)
# -----------------------------
REDIS_URL="redis://localhost:6379"  # Redis connection URL
REDIS_PORT=6379  # Redis port (default is 6379)
